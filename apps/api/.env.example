# API Server Configuration (FastAPI/Python)
# Copy this file to apps/api/.env and fill in your actual values

# Database URL (PostgreSQL - placeholder)
DATABASE_URL=postgresql://user:password@localhost:5432/myapp

# Secret Key (for JWT tokens, session management, etc.)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-secret-key-here

# ============================================
# Authentication (Clerk)
# ============================================
# Get your secret key from: https://dashboard.clerk.com
# This is a server-only key for authentication
CLERK_SECRET_KEY=sk_test_your_clerk_secret_key

# ============================================
# Ingest (POST /ingest - server-only, scraper → API)
# ============================================
# When set, POST /ingest requires Authorization: Bearer <key> or X-Ingest-Secret
# Do not expose to mobile. See root .env.example for backoff tuning.
INGEST_API_KEY=

# Optional: per-IP backoff after failed ingest auth
# INGEST_BACKOFF_BASE_SEC=60
# INGEST_BACKOFF_MAX_EXPONENT=10

# ============================================
# Analytics (PostHog)
# ============================================
# Get your API key from: https://app.posthog.com/project/settings
POSTHOG_API_KEY=phc_your_posthog_api_key

# Optional: PostHog host (defaults to https://app.posthog.com)
# POSTHOG_HOST=https://app.posthog.com

# ============================================
# Convex Deployment
# ============================================
# Convex Deployment (for server-side auth with Convex)
CONVEX_DEPLOYMENT=your-convex-deployment

# CORS Origins (comma-separated list of allowed origins)
CORS_ORIGINS=http://localhost:8081,http://localhost:3000

# Logging Level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Optional: Rate limiting settings
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=60

# ============================================
# Qdrant Vector Database
# ============================================
# Mode: local, docker, cloud, memory
QDRANT_MODE=docker
QDRANT_HOST=localhost
QDRANT_PORT=6333
# For cloud mode:
# QDRANT_URL=https://your-cluster.qdrant.io
# QDRANT_API_KEY=your-api-key

# ============================================
# Embeddings
# ============================================
# Provider: local (fastembed) or openai
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
# For OpenAI:
# OPENAI_API_KEY=sk-...
