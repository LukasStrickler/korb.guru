# Mobile App Configuration (Expo/React Native)
# Copy this file to apps/mobile/.env and fill in your actual values

# ============================================
# Authentication (Clerk)
# ============================================
# Get your publishable key from: https://dashboard.clerk.com
# This is a public key that can be exposed to the client
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_clerk_publishable_key

# ============================================
# Analytics (PostHog)
# ============================================
# Get your API key from: https://app.posthog.com/project/settings
EXPO_PUBLIC_POSTHOG_API_KEY=phc_your_posthog_api_key

# Optional: Custom PostHog host (defaults to https://app.posthog.com)
# EXPO_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# ============================================
# Backend Configuration
# ============================================
# Convex Database URL (Publicly accessible for client-side)
EXPO_PUBLIC_CONVEX_URL=your-convex-url

# API Base URL (Point to local FastAPI during dev)
EXPO_PUBLIC_API_BASE_URL=http://localhost:8000

# Optional: Not used by the app. Never set to ingest/secret keys.
# EXPO_PUBLIC_API_KEY=

# ============================================
# Feature Flags
# ============================================
EXPO_PUBLIC_ENABLE_ANALYTICS=false
EXPO_PUBLIC_DEBUG_MODE=true
