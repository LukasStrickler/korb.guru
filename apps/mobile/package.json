{
  "name": "@korb/mobile",
  "version": "0.0.1",
  "private": true,
  "description": "Korb Guru mobile app - Expo React Native",
  "main": "expo-router/entry",
  "scripts": {
    "dev": "expo start",
    "dev:android": "expo start --android",
    "dev:ios": "expo start --ios",
    "build": "expo export --platform ios",
    "build:android": "expo export --platform android",
    "build:ios": "expo export --platform ios",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx -c eslint.config.mjs",
    "typecheck": "tsc --noEmit",
    "test": "jest --runInBand",
    "test:unit": "jest --runInBand --testPathPattern='\\.unit\\.test\\.'",
    "test:integration": "jest --runInBand --testPathPattern='\\.integration\\.test\\.'",
    "test:component": "jest --runInBand --testPathPattern='\\.component\\.test\\.'",
    "test:watch": "jest --watch",
    "test:unit:watch": "jest --watch --testPathPattern='\\.unit\\.test\\.'",
    "test:integration:watch": "jest --watch --testPathPattern='\\.integration\\.test\\.'",
    "test:coverage": "jest --runInBand --coverage",
    "test:quarantine": "jest --config jest.flaky.config.js --runInBand",
    "test:quarantine:watch": "jest --config jest.flaky.config.js --watch",
    "test:quarantine:stability": "node scripts/test-quarantine-stability.mjs 10",
    "test:mutation": "stryker run",
    "test:e2e": "maestro test .maestro/",
    "storybook": "EXPO_PUBLIC_ENVIRONMENT=storybook expo start",
    "storybook:web": "storybook dev -p 6006",
    "storybook:ios": "EXPO_PUBLIC_ENVIRONMENT=storybook expo start --ios",
    "storybook:android": "EXPO_PUBLIC_ENVIRONMENT=storybook expo start --android",
    "storybook:tunnel": "EXPO_PUBLIC_ENVIRONMENT=storybook expo start --tunnel",
    "storybook:lan": "EXPO_PUBLIC_ENVIRONMENT=storybook expo start --lan",
    "storybook-generate": "sb-rn-get-stories",
    "check": "pnpm run lint && pnpm run typecheck",
    "check:security": "node scripts/check-mobile-security.cjs",
    "clean": "rm -rf node_modules dist .expo coverage"
  },
  "dependencies": {
    "@babel/runtime": "^7.24.0",
    "@clerk/clerk-expo": "2.19.31",
    "@expo/metro-runtime": "~55.0.6",
    "@korb/contracts": "workspace:*",
    "@react-native-async-storage/async-storage": "2.1.2",
    "@react-native-community/netinfo": "^11.5.2",
    "convex": "^1.24.0",
    "expo": "~55.0.5",
    "expo-apple-authentication": "~55.0.0",
    "expo-constants": "~55.0.7",
    "expo-crypto": "~55.0.0",
    "expo-linking": "~55.0.7",
    "expo-router": "~55.0.4",
    "expo-secure-store": "~55.0.8",
    "expo-splash-screen": "~55.0.10",
    "expo-status-bar": "~55.0.4",
    "expo-system-ui": "~55.0.9",
    "nativewind": "^4.2.2",
    "posthog-react-native": "^3.0.0",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.2",
    "react-native-css-interop": "^0.2.2",
    "react-native-error-boundary": "^3.1.0",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-reanimated": "~4.2.1",
    "react-native-safe-area-context": "5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-web": "^0.21.0",
    "react-native-worklets": "^0.7.2",
    "tailwindcss": "^3.4.19"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@korb/config": "workspace:*",
    "@storybook/addon-docs": "^10.2.16",
    "@storybook/react": "^10.2.16",
    "@storybook/react-native": "^10.2.3",
    "@storybook/react-native-web-vite": "^10.2.16",
    "@stryker-mutator/core": "^9.6.0",
    "@stryker-mutator/jest-runner": "^9.6.0",
    "@testing-library/react-native": "^13.2.0",
    "@types/jest": "^29.5.12",
    "@types/react": "~19.2.14",
    "@types/react-native": "~0.73.0",
    "babel-plugin-module-resolver": "^5.0.2",
    "jest": "^29.7.0",
    "jest-expo": "~55.0.9",
    "msw": "^2.7.0",
    "storybook": "^10.2.16",
    "typescript": "^5.7.0",
    "vite": "^7.3.1"
  },
  "peerDependencies": {
    "react": "*",
    "react-native": "*"
  }
}
