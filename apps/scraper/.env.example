# Scraper Configuration (Headless Browser)
# Copy this file to apps/scraper/.env and fill in your actual values

# -----------------------------------------------------------------------------
# Scraper Ingestion Pipeline
# -----------------------------------------------------------------------------
# The scraper is a data ingestion tool. It does NOT participate in the shared
# Clerk/PostHog auth/analytics contract. Instead:
#
# - Scraper produces data (recipes, users, etc.) in JSON/JSONL format
# - Data is emitted to: stdout, file, FastAPI /ingest endpoint, or Convex
# - Auth/analytics is handled upstream by mobile app (Clerk) and API server
#
# See: apps/api/.env.example for FastAPI /ingest endpoint integration
# See: apps/convex/.env.example for Convex data ingestion
# See: root .env.example for shared service overview
# -----------------------------------------------------------------------------
#
# When using --sink fastapi or --sink convex, the scraper sends auth via
# Authorization: Bearer <token>. Use one of (server-only; do not expose to client):
#   INGEST_API_KEY=...
#   SCRAPER_INGEST_API_TOKEN=...
# Or pass --api-token on the CLI (prefer env to avoid process list exposure).
# -----------------------------------------------------------------------------

# Scraper Configuration (JSON format)
SCRAPER_CONFIG={"user_agent":"Mozilla/5.0","headless":true,"timeout":30000,"retry_attempts":3,"proxy":"optional"}

# Output Format (json, csv, xml)
OUTPUT_FORMAT=json

# Output Directory (absolute or relative path)
OUTPUT_DIR=./output

# Optional: Scraper-specific settings
SCRAPER_DELAY=1000
SCRAPER_MAX_PAGES=10
SCRAPER_FILTER_ENABLED=true

# Optional: Logging
SCRAPER_LOG_LEVEL=INFO
