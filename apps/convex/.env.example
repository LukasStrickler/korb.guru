# Convex Backend Configuration
# Copy this file to apps/convex/.env and fill in your actual values

# ============================================
# Convex Deployment
# ============================================
# Get your deployment URL from: https://dashboard.convex.dev
# This is used for server-side operations
CONVEX_DEPLOYMENT=your-convex-deployment-url

# ============================================
# Convex Server Settings
# ============================================
# CORS Origins (comma-separated list of allowed origins)
CONVEX_CORS_ORIGINS=http://localhost:8081,http://localhost:3000

# Logging Level (DEBUG, INFO, WARNING, ERROR)
CONVEX_LOG_LEVEL=INFO

# Optional: Rate limiting settings
CONVEX_RATE_LIMIT_ENABLED=true
CONVEX_RATE_LIMIT_PER_MINUTE=60

# -----------------------------------------------------------------------------
# Shared Auth/Analytics Contract
# -----------------------------------------------------------------------------
# Convex does NOT own Clerk or PostHog keys. It consumes auth/analytics from
# upstream services:
#
# - Clerk Auth: Configured in Convex Dashboard as CLERK_JWT_ISSUER_DOMAIN (not env file)
#   See: https://docs.convex.dev/auth/clerk
#   - The mobile client provides Clerk JWT automatically via ConvexProviderWithClerk
#   - Convex functions verify JWT using ctx.auth.getUserIdentity()
#
# - PostHog Analytics: No direct integration in scaffold
#   - Analytics events flow through FastAPI server layer
#   - Convex only receives data mutations (no client-side tracking)
#
# See root .env.example and apps/mobile/.env.example for Clerk/PostHog config
# See apps/api/.env.example for server-side PostHog integration
# -----------------------------------------------------------------------------
