# Monorepo Configuration (central .env for local development)
# Copy this file to .env at the repo root and fill in your actual values.
# Run dev from root (pnpm dev, pnpm dev:mobile, etc.) so dotenv-cli injects these into all apps.
# Production: set variables in your deployment platform (e.g. Coolify UI), not in repo or root .env.
# See .docs/guides/local-dev.md for deployment vs dev and per-app overrides.
#
# DEV vs PRODUCTION:
# - Variables marked [DEV PLACEHOLDER] work for local development only
# - Variables marked [PRODUCTION REQUIRED] must be set for production
# - Variables marked [OPTIONAL] can be left empty or omitted
#
# For full documentation, see:
# - .docs/guides/local-dev.md (setup and port map)
# - .docs/reference/auth.md (auth-related variables)
# - apps/<name>/README.md (app-specific variables)

# -----------------------------------------------------------------------------
# Mobile App (apps/mobile) - REQUIRED for mobile development
# Use these values from apps/mobile/.env or root .env
# All mobile values must use EXPO_PUBLIC_ prefix for client-side access
# -----------------------------------------------------------------------------
# Authentication (Clerk) - REQUIRED
# Public key for mobile app - can be exposed to client
# Get from: https://dashboard.clerk.com
# [DEV PLACEHOLDER] Falls back to test key in dev if unset
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_clerk_publishable_key
# Analytics (PostHog) - OPTIONAL
# Public key for mobile analytics
# Get from: https://app.posthog.com/project/settings
# [OPTIONAL] Analytics disabled if unset
EXPO_PUBLIC_POSTHOG_API_KEY=
EXPO_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# Convex Database - REQUIRED
# Your Convex dev deployment URL from `pnpm --filter @korb/convex dev`
# [DEV PLACEHOLDER] Falls back to example URL in dev if unset
EXPO_PUBLIC_CONVEX_URL=your-convex-url
# FastAPI Backend - REQUIRED
# [DEV PLACEHOLDER] Use localhost for iOS sim, 10.0.2.2 for Android emulator
EXPO_PUBLIC_API_BASE_URL=http://localhost:8000
# Feature Flags - OPTIONAL
# [OPTIONAL] These control dev features and can be left as-is for local dev
EXPO_PUBLIC_ENABLE_ANALYTICS=false
EXPO_PUBLIC_DEBUG_MODE=true
# -----------------------------------------------------------------------------
# Backend Services (apps/api, apps/convex, apps/scraper)
# These are server-only secrets - do not expose to mobile
# -----------------------------------------------------------------------------

# API Server - OPTIONAL for scaffold
# [OPTIONAL] For local dev: start Postgres + Qdrant with pnpm db:up (see apps/postgres/ and apps/qdrant/). Wipe and reload example data: pnpm db:reset.
DATABASE_URL=postgresql://user:password@localhost:5432/myapp
# Vector DB (Qdrant). Local: pnpm db:up then use http://localhost:6333. Deploy: set to Coolify or remote URL.
# [OPTIONAL] Set for deploy if Qdrant uses API key auth.
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
SECRET_KEY=your-secret-key-here
LOG_LEVEL=INFO
# Clerk (Server-side only) - OPTIONAL for dev
# [DEV PLACEHOLDER] Leave unset for dev placeholder auth
# [PRODUCTION REQUIRED] Set for production JWT verification
CLERK_SECRET_KEY=
# Clerk Webhook Secret (Svix) - REQUIRED for webhook verification
# Get from: Clerk Dashboard -> Webhooks -> Endpoint -> Signing Secret
# [PRODUCTION REQUIRED] Must be set for production webhook security
CLERK_WEBHOOK_SECRET=
# Ingest (Server-only: scraper → API POST /ingest)
# If set, POST /ingest requires Authorization: Bearer <key> or X-Ingest-Secret: <key>
# Scraper uses INGEST_API_KEY or SCRAPER_INGEST_API_TOKEN from env when --api-token not passed
INGEST_API_KEY=
# Per-IP exponential backoff after failed ingest auth (optional)
# INGEST_BACKOFF_BASE_SEC=60
# INGEST_BACKOFF_MAX_EXPONENT=10

# PostHog (Server-side) - OPTIONAL
# [OPTIONAL] Server-side analytics; leave empty to disable
POSTHOG_API_KEY=
POSTHOG_HOST=https://app.posthog.com
# Convex Deployment - REQUIRED for convex dev/deploy
# [DEV PLACEHOLDER] Set after running `pnpm --filter @korb/convex dev`
CONVEX_DEPLOYMENT=
# Scraper Configuration - OPTIONAL
# [OPTIONAL] Mock mode works without these; only needed for real scraping
SCRAPER_CONFIG={"user_agent":"Mozilla/5.0","headless":true,"timeout":30000,"retry_attempts":3}
OUTPUT_FORMAT=json
OUTPUT_DIR=./output
# Rate limiting - OPTIONAL
# [OPTIONAL] Per-IP rate limiting for ingest endpoint
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=60
