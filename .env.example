# Monorepo Configuration
# Copy this file to .env and fill in your actual values

# -----------------------------------------------------------------------------
# Mobile App (apps/mobile)
# Use these values from apps/mobile/.env or root .env
# All mobile values must use EXPO_PUBLIC_ prefix for client-side access
# -----------------------------------------------------------------------------

# Authentication (Clerk)
# Public key for mobile app - can be exposed to client
# Get from: https://dashboard.clerk.com
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_clerk_publishable_key

# Analytics (PostHog)
# Public key for mobile analytics
# Get from: https://app.posthog.com/project/settings
EXPO_PUBLIC_POSTHOG_API_KEY=phc_your_posthog_api_key
EXPO_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# Convex Database (Public)
EXPO_PUBLIC_CONVEX_URL=your-convex-url

# FastAPI Backend (Public for dev)
EXPO_PUBLIC_API_BASE_URL=http://localhost:8000

# Feature Flags (Public)
EXPO_PUBLIC_ENABLE_ANALYTICS=false
EXPO_PUBLIC_DEBUG_MODE=true

# -----------------------------------------------------------------------------
# Backend Services (apps/api, apps/convex, apps/scraper)
# These are server-only secrets - do not expose to mobile
# -----------------------------------------------------------------------------

# API Server
DATABASE_URL=postgresql://user:password@localhost:5432/myapp
SECRET_KEY=your-secret-key-here
LOG_LEVEL=INFO

# Clerk (Server-side only)
CLERK_SECRET_KEY=sk_test_your_clerk_secret_key

# Ingest (Server-only: scraper → API POST /ingest)
# If set, POST /ingest requires Authorization: Bearer <key> or X-Ingest-Secret: <key>
# Scraper uses INGEST_API_KEY or SCRAPER_INGEST_API_TOKEN from env when --api-token not passed
INGEST_API_KEY=
# Per-IP exponential backoff after failed ingest auth (optional)
# INGEST_BACKOFF_BASE_SEC=60
# INGEST_BACKOFF_MAX_EXPONENT=10

# PostHog (Server-side)
POSTHOG_API_KEY=phc_your_posthog_api_key
POSTHOG_HOST=https://app.posthog.com

# Convex Deployment
CONVEX_DEPLOYMENT=your-convex-deployment-url

# Scraper Configuration
SCRAPER_CONFIG={"user_agent":"Mozilla/5.0","headless":true,"timeout":30000,"retry_attempts":3,"proxy":"optional"}
OUTPUT_FORMAT=json
OUTPUT_DIR=./output

# Optional: Rate limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=60
