# ============================================================
# korb.guru Environment Configuration
# Copy to .env and fill in your values
# ============================================================

# --- PostgreSQL ---
POSTGRES_USER=korb
POSTGRES_PASSWORD=CHANGE_ME_IN_PRODUCTION
POSTGRES_DB=korb_guru
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
# DATABASE_URL is auto-built from the above vars. Override only if needed:
# DATABASE_URL=postgresql+psycopg://korb:korb_secret@postgres:5432/korb_guru

# --- Qdrant ---
# Mode: "docker" for local docker-compose, "cloud" for Qdrant Cloud, "memory" for tests
QDRANT_MODE=docker

# Only needed when QDRANT_MODE=cloud:
# QDRANT_URL=https://xxx.cloud.qdrant.io:6333
# QDRANT_API_KEY=your-qdrant-cloud-key

# Only needed when QDRANT_MODE=docker (defaults work with docker-compose):
QDRANT_HOST=qdrant
QDRANT_PORT=6333

# --- Embeddings ---
EMBEDDING_PROVIDER=local
# Only needed when EMBEDDING_PROVIDER=openai:
# OPENAI_API_KEY=sk-...

# --- LLM (at least one required for AI features) ---
# Primary: Apify OpenRouter proxy (cheaper)
APIFY_TOKEN=your-apify-token
# Fallback: Direct OpenRouter API
# OPENROUTER_API_KEY=your-openrouter-key
# Default model for LLM calls:
# OPENROUTER_DEFAULT_MODEL=google/gemini-2.5-flash

# --- App ---
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
LOG_LEVEL=INFO
